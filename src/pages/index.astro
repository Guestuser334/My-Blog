---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, CURRENT_LOCATION } from '../consts';

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 3);
const latestPost = posts[0];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.widget-grid {
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
				padding: 1.5rem 0;
			}
			.row-flex {
				display: flex;
				gap: 1.5rem;
			}
			.w-60 { width: 60%; }
			.w-40 { width: 40%; }
			.w-35 { width: 35%; }
			.w-65 { width: 65%; }
			.w-100 { width: 100%; }

			/* Search Widget */
			.search-widget {
				padding: 1rem 1.5rem;
			}
			.search-inner {
				display: flex;
				align-items: center;
				gap: 0.8rem;
				color: var(--text-muted);
				font-size: 1.05rem;
				cursor: text;
			}
			.search-inner svg {
				opacity: 0.6;
			}

			/* Profile Card */
			.profile-card {
				display: flex;
				flex-direction: column;
				justify-content: space-between;
				height: 250px;
			}
			.profile-top {
				display: flex;
				gap: 1.5rem;
				align-items: center;
			}
			.profile-avatar {
				width: 80px;
				height: 80px;
				border-radius: 20px;
				object-fit: cover;
				border: 2px solid var(--glass-border);
				box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
			}
			.profile-info h2 {
				margin: 0 0 0.3rem 0;
				font-size: 1.7rem;
				font-weight: 800;
				letter-spacing: -0.02em;
			}
			.profile-info p {
				margin: 0;
				font-size: 1rem;
				color: var(--text-muted);
				line-height: 1.5;
			}
			.profile-bottom {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-top: 1rem;
			}
			.profile-stats {
				display: flex;
				gap: 1.5rem;
			}
			.stat-item {
				text-align: center;
			}
			.stat-val {
				font-size: 1.45rem;
				font-weight: 800;
				color: var(--accent);
				display: block;
			}
			.stat-lbl {
				font-size: 0.85rem;
				color: var(--text-muted);
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}
			.profile-socials {
				display: flex;
				gap: 0.6rem;
			}
			.social-btn {
				width: 38px;
				height: 38px;
				border-radius: 50%;
				background: rgba(var(--accent-color), 0.05);
				border: 1px solid rgba(var(--accent-color), 0.1);
				display: flex;
				align-items: center;
				justify-content: center;
				color: var(--text-color);
				transition: all 0.2s;
			}
			.social-btn:hover {
				background: var(--accent);
				color: white !important;
				transform: translateY(-2px);
				box-shadow: 0 4px 12px rgba(var(--accent-color), 0.35);
			}

			/* Map Widget - Obsidian Contrast Design */
			.map-widget {
				height: 250px;
				display: flex;
				flex-direction: column;
				justify-content: space-between;
				position: relative;
				overflow: hidden;
				background: rgba(18, 18, 24, 0.93) !important;
				border: 1px solid rgba(255, 255, 255, 0.12) !important;
				box-shadow: 0 10px 30px 0 rgba(0, 0, 0, 0.3) !important;
				color: #f5f5f7 !important;
			}
			.map-header h3 {
				margin: 0;
				font-size: 1.05rem;
				color: #ffffff;
			}
			.map-title-wrapper {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				color: #ffffff;
			}

			/* SVG Map */
			.svg-map-wrapper {
				flex-grow: 1;
				position: relative;
				overflow: hidden;
				margin: 0.2rem 0;
			}
			.svg-map-wrapper svg {
				width: 100%;
				height: 100%;
			}
			.map-land {
				display: none;
			}
			.country-path {
				fill: none !important;
				stroke: none !important;
				pointer-events: none !important;
			}
			:global(.map-dot) {
				fill: rgba(255, 255, 255, 0.08);
				transition: fill 0.3s;
			}
			:global(.map-dot.active-land) {
				fill: var(--accent) !important;
				opacity: 0.95;
			}
			.city-marker {
				fill: #10b981;
				filter: drop-shadow(0 0 4px #10b981);
				animation: pulse-city 2s infinite;
			}
			.city-ring {
				fill: none;
				stroke: #10b981;
				stroke-width: 0.6;
				animation: expand-ring 2s infinite;
				transform-box: fill-box;
				transform-origin: center;
			}
			@keyframes pulse-city {
				0%, 100% { opacity: 1; r: 2.2; }
				50% { opacity: 0.7; r: 3.5; }
			}
			@keyframes expand-ring {
				0% { transform: scale(1); opacity: 0.8; }
				100% { transform: scale(3.5); opacity: 0; }
			}

			.location-footer {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				font-size: 0.85rem;
				border-top: 1px solid rgba(255, 255, 255, 0.08);
				padding-top: 0.4rem;
			}
			.location-dot-pulse {
				width: 8px;
				height: 8px;
				border-radius: 50%;
				background-color: #10b981;
				box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
				animation: pulse 2s infinite;
			}
			.location-text {
				color: rgba(255, 255, 255, 0.75);
			}
			.location-text strong {
				color: var(--accent);
			}

			/* Status Banner / Lyric Marquee */
			.status-banner {
				padding: 0.8rem 1.5rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
				font-size: 0.95rem;
				overflow: hidden;
			}
			.lyric-text {
				font-weight: 700;
				color: var(--accent);
				text-shadow: 0 1px 3px rgba(255, 255, 255, 0.85);
			}
			:root[data-theme="dark"] .lyric-text {
				text-shadow: 0 0 10px rgba(var(--accent-color), 0.4);
			}
			@media (prefers-color-scheme: dark) {
				:root:not([data-theme="light"]) .lyric-text {
					text-shadow: 0 0 10px rgba(var(--accent-color), 0.4);
				}
			}

			/* Featured Post Card */
			.featured-widget {
				display: flex;
				flex-direction: column;
				gap: 1rem;
				justify-content: space-between;
				color: inherit;
				text-decoration: none;
			}
			.featured-tag {
				font-size: 0.7rem;
				font-weight: 800;
				color: white;
				background: linear-gradient(135deg, var(--accent), #f43f5e);
				padding: 3px 8px;
				border-radius: 6px;
				align-self: flex-start;
				letter-spacing: 0.05em;
				text-transform: uppercase;
			}
			.featured-img {
				width: 100%;
				height: 160px;
				object-fit: cover;
				border-radius: 14px;
				border: 1px solid var(--glass-border);
			}
			.featured-widget h3 {
				margin: 0;
				font-size: 1.35rem;
				line-height: 1.3;
				color: var(--text-color);
				transition: color 0.2s;
			}
			.featured-widget:hover h3 {
				color: var(--accent);
			}
			.featured-widget p {
				font-size: 0.95rem;
				color: var(--text-muted);
				margin: 0;
				line-height: 1.5;
				display: -webkit-box;
				-webkit-line-clamp: 3;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.featured-bottom {
				display: flex;
				justify-content: space-between;
				align-items: center;
				font-size: 0.9rem;
				color: var(--text-muted);
				margin-top: 0.5rem;
			}

			/* Right Grid Section (Posts List + Theme Widget) */
			.right-content-grid {
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
				height: 100%;
			}
			
			/* Recent Posts Widget */
			.recent-posts-widget {
				flex-grow: 1;
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}
			.widget-title {
				font-size: 1.25rem;
				font-weight: 800;
				margin: 0 0 0.5rem 0;
				display: flex;
				align-items: center;
				gap: 0.5rem;
			}
			.post-row {
				display: flex;
				justify-content: space-between;
				align-items: center;
				padding: 0.6rem 0.8rem;
				border-radius: 12px;
				transition: background-color 0.2s, transform 0.2s;
			}
			.post-row:hover {
				background: rgba(var(--accent-color), 0.05);
				transform: translateX(4px);
			}
			.post-title-link {
				color: var(--text-color);
				font-weight: 600;
				font-size: 1.05rem;
				white-space: nowrap;
				overflow: hidden;
				text-overflow: ellipsis;
				max-width: 70%;
			}
			.post-row:hover .post-title-link {
				color: var(--accent);
			}
			.post-meta-tag {
				font-size: 0.9rem;
				color: var(--text-muted);
			}

			/* Bottom sub-row */
			.sub-row {
				display: flex;
				gap: 1.5rem;
			}
			.w-50 { width: 50%; }

			/* Theme Widget */
			.theme-widget {
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				text-align: center;
				padding: 1.5rem 1rem;
				position: relative;
			}
			.theme-circle {
				width: 50px;
				height: 50px;
				border-radius: 50%;
				background: linear-gradient(135deg, #00f2fe 0%, #4facfe 100%);
				box-shadow: 0 4px 15px rgba(79, 172, 254, 0.4);
				margin-bottom: 0.8rem;
				animation: spin 8s linear infinite;
			}
			:root[data-theme="dark"] .theme-circle {
				background: linear-gradient(135deg, #f39c12 0%, #f1c40f 100%);
				box-shadow: 0 4px 15px rgba(241, 196, 15, 0.4);
			}
			@media (prefers-color-scheme: dark) {
				:root:not([data-theme="light"]) .theme-circle {
					background: linear-gradient(135deg, #f39c12 0%, #f1c40f 100%);
					box-shadow: 0 4px 15px rgba(241, 196, 15, 0.4);
				}
			}
			.theme-widget h4 {
				margin: 0 0 0.2rem 0;
				font-size: 1.08rem;
				font-weight: 700;
			}
			.theme-widget p {
				margin: 0;
				font-size: 0.85rem;
				color: var(--text-muted);
			}

			/* Tech Stack Widget */
			.tech-widget {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				align-content: center;
				justify-content: center;
				padding: 1.2rem;
			}
			.tech-badge {
				font-size: 0.85rem;
				padding: 5px 10px;
				border-radius: 8px;
				background: rgba(255, 255, 255, 0.15);
				border: 1px solid var(--glass-border);
				color: var(--text-color);
				font-weight: 600;
			}
			:root[data-theme="dark"] .tech-badge {
				background: rgba(0, 0, 0, 0.25);
			}
			@media (prefers-color-scheme: dark) {
				:root:not([data-theme="light"]) .tech-badge {
					background: rgba(0, 0, 0, 0.25);
				}
			}

			/* Status / Footer bar */
			/* Status / Footer bar */
			.footer-bar {
				padding: 1rem 2rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
				font-size: 0.9rem;
				color: var(--text-color);
			}
			
			.footer-left {
				display: flex;
				align-items: center;
				gap: 1.2rem;
			}
			.clock-wrapper {
				display: flex;
				align-items: center;
				gap: 0.4rem;
				background: rgba(124, 58, 237, 0.08);
				border: 1px solid rgba(124, 58, 237, 0.15);
				padding: 0.3rem 0.8rem;
				border-radius: 12px;
				font-weight: 700;
				color: rgb(124, 58, 237);
				font-variant-numeric: tabular-nums;
				text-shadow: 0 1px 2px rgba(255, 255, 255, 0.5);
			}
			:root[data-theme="dark"] .clock-wrapper {
				background: rgba(167, 139, 250, 0.12);
				border-color: rgba(167, 139, 250, 0.22);
				color: rgb(167, 139, 250);
				text-shadow: none;
			}
			@media (prefers-color-scheme: dark) {
				:root:not([data-theme="light"]) .clock-wrapper {
					background: rgba(167, 139, 250, 0.12);
					border-color: rgba(167, 139, 250, 0.22);
					color: rgb(167, 139, 250);
					text-shadow: none;
				}
			}
			
			.runtime-wrapper {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				font-size: 0.85rem;
				color: var(--text-muted);
			}
			.status-pulse {
				width: 8px;
				height: 8px;
				border-radius: 50%;
				background-color: #10b981;
				box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
				animation: pulse 2s infinite;
			}
			@keyframes pulse {
				0% {
					transform: scale(0.95);
					box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
				}
				70% {
					transform: scale(1);
					box-shadow: 0 0 0 6px rgba(16, 185, 129, 0);
				}
				100% {
					transform: scale(0.95);
					box-shadow: 0 0 0 0 rgba(16, 185, 129, 0);
				}
			}

			.footer-right {
				display: flex;
				align-items: center;
				gap: 1.5rem;
			}
			.tech-badges-list {
				display: flex;
				gap: 0.5rem;
			}
			.tech-badge-pill {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				padding: 0.2rem 0.6rem;
				border-radius: 8px;
				font-size: 0.75rem;
				font-weight: 600;
				border: 1px solid rgba(var(--accent-color), 0.15);
				background: rgba(var(--accent-color), 0.05);
				color: var(--text-color);
				transition: transform 0.2s, background-color 0.2s;
			}
			.tech-badge-pill:hover {
				transform: translateY(-1px);
			}
			.tech-badge-pill .dot-indicator {
				width: 6px;
				height: 6px;
				border-radius: 50%;
			}
			.tech-badge-pill.astro-pill {
				border-color: rgba(255, 94, 0, 0.2);
				background: rgba(255, 94, 0, 0.08);
				color: #e65c00;
			}
			:root[data-theme="dark"] .tech-badge-pill.astro-pill {
				color: #ff8533;
			}
			.tech-badge-pill.vite-pill {
				border-color: rgba(100, 108, 255, 0.2);
				background: rgba(100, 108, 255, 0.08);
				color: #4f46e5;
			}
			:root[data-theme="dark"] .tech-badge-pill.vite-pill {
				color: #818cf8;
			}
			.tech-badge-pill.react-pill {
				border-color: rgba(8, 126, 164, 0.2);
				background: rgba(8, 126, 164, 0.08);
				color: #087ea4;
			}
			:root[data-theme="dark"] .tech-badge-pill.react-pill {
				color: #22d3ee;
			}
			.icp-link {
				font-size: 0.8rem;
				color: var(--text-muted);
				transition: color 0.2s;
			}
			.icp-link:hover {
				color: var(--accent);
			}

			/* Keyframes */
			@keyframes spin {
				from { transform: rotate(0deg); }
				to { transform: rotate(360deg); }
			}
			@keyframes blink {
				from, to { border-color: transparent }
				50% { border-color: var(--accent); }
			}

			/* Responsive styling */
			@media (max-width: 768px) {
				.row-flex {
					flex-direction: column;
					gap: 1rem;
				}
				.w-60, .w-40, .w-35, .w-65, .w-50 {
					width: 100% !important;
				}
				.profile-card, .map-widget {
					height: auto;
				}
				.sub-row {
					flex-direction: column;
					gap: 1rem;
				}
				.footer-bar {
					flex-direction: column;
					gap: 0.5rem;
					text-align: center;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="widget-grid">
				
				<!-- Search / Welcome Bar -->
				<div class="glass-card search-widget">
					<div class="search-inner">
						<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
							<circle cx="11" cy="11" r="8"></circle>
							<line x1="21" y1="21" x2="16.65" y2="16.65"></line>
						</svg>
						<span>搜索文章标题或正文内容...</span>
					</div>
				</div>

				<!-- Row 1: Profile + Music Player -->
				<div class="row-flex">
					<!-- Profile Card -->
					<div class="glass-card profile-card w-60">
						<div class="profile-top">
							<img src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?q=80&w=150&auto=format&fit=crop" alt="Avatar" class="profile-avatar" />
							<div class="profile-info">
								<h2>Hi, I'm Skittles!</h2>
								<p>Grade 2024 student in EE, Xi'an Jiaotong University<br />
								   Designing quantitative trading based on power grids<br />
								   I am learning everything I found interesting<br />
								</p>
							</div>
						</div>
						<div class="profile-bottom">
							<div class="profile-stats">
								<div class="stat-item">
									<span class="stat-val">{allPosts.length}</span>
									<span class="stat-lbl">文章</span>
								</div>
								<div class="stat-item">
									<span class="stat-val">3</span>
									<span class="stat-lbl">分类</span>
								</div>
								<div class="stat-item">
									<span class="stat-val">12</span>
									<span class="stat-lbl">标签</span>
								</div>
							</div>
							<div class="profile-socials">
								<a href="https://github.com/withastro/astro" target="_blank" class="social-btn" aria-label="GitHub">
									<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
									</svg>
								</a>
								<a href="#" class="social-btn" aria-label="WeChat">
									<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
									</svg>
								</a>
								<a href="mailto:example@example.com" class="social-btn" aria-label="Mail">
									<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
										<polyline points="22,6 12,13 2,6"></polyline>
									</svg>
								</a>
							</div>
						</div>
					</div>

					<!-- Interactive Location Map Card - SVG based -->
					<div class="glass-card map-widget w-40">
						<div class="map-header">
							<div class="map-title-wrapper">
								<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<circle cx="12" cy="12" r="10"></circle>
									<line x1="2" y1="12" x2="22" y2="12"></line>
									<path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
								</svg>
								<h3>My location</h3>
							</div>
						</div>

						<!-- SVG World Map -->
						<div class="svg-map-wrapper">
							<svg id="world-map-svg" viewBox="0 0 1010 505" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">
								<!-- Simplified Natural Earth world map paths -->
								<!-- North America -->
								<path class="map-land" d="M108,55 L155,45 L185,50 L210,65 L220,80 L215,100 L200,115 L175,120 L155,110 L140,95 L120,85 L105,70 Z"/>
								<path class="map-land" d="M155,45 L210,38 L250,42 L280,55 L290,75 L275,90 L255,95 L230,88 L210,65 L185,50 Z"/>
								<!-- High-fidelity country paths loaded dynamically at runtime -->
								<g id="map-paths-group"></g>
								
								<!-- Dynamic dot matrix grid container -->
								<g id="dot-grid-group"></g>
								
								<!-- Location marker - updated by JS -->
								<g id="city-marker-group" style="display: none;">
									<circle class="city-ring" id="city-ring" cx="0" cy="0" r="10"/>
									<circle class="city-marker" id="city-dot" cx="0" cy="0" r="4"/>
								</g>
							</svg>
						</div>

						<!-- Current Location Info -->
						<div class="location-footer">
							<span class="location-dot-pulse"></span>
							<span class="location-text">📍 Currently in：<strong id="current-location-display">Xi'an</strong></span>
						</div>
					</div>
				</div>

				<!-- Row 2: Status Bar / Lyric Marquee -->
				<div class="glass-card status-banner w-100">
					<div>
						<span>签名：</span>
						<span id="typing-lyric" class="lyric-text">独有南山桂花发，飞来飞去袭人裾。</span>
					</div>
					<div style="opacity: 0.7;">
						<span>🔋 系统运行稳定中</span>
					</div>
				</div>

				<!-- Row 3: Grid containing Featured Post + Right Side Widgets -->
				<div class="row-flex">
					<!-- Featured Post Card -->
					<a href={`/blog/${latestPost.id}/`} class="glass-card glass-card-hover featured-widget w-35">
						<span class="featured-tag">LATEST POST</span>
						<img src="https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=400" alt="Cover" class="featured-img" />
						<div>
							<h3>{latestPost.data.title}</h3>
							<p style="margin-top: 0.5rem;">{latestPost.data.description}</p>
						</div>
						<div class="featured-bottom">
							<span>阅读全文 &rarr;</span>
							<span>2026/07/05</span>
						</div>
					</a>

					<!-- Right Columns Widget Grid -->
					<div class="w-65 right-content-grid">
						<!-- Recent Posts List -->
						<div class="glass-card recent-posts-widget">
							<h3 class="widget-title">
								<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
									<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
									<polyline points="14 2 14 8 20 8"></polyline>
									<line x1="16" y1="13" x2="8" y2="13"></line>
									<line x1="16" y1="17" x2="8" y2="17"></line>
									<polyline points="10 9 9 9 8 9"></polyline>
								</svg>
								最近发表
							</h3>
							{
								posts.map((post) => (
									<div class="post-row">
										<a href={`/blog/${post.id}/`} class="post-title-link">
											{post.data.title}
										</a>
										<span class="post-meta-tag">
											2026 / 07 / 05
										</span>
									</div>
								))
							}
						</div>

						<!-- Sub Row for widgets -->
						<div class="sub-row">
							<!-- Theme Display Widget -->
							<div class="glass-card theme-widget w-50">
								<div class="theme-circle"></div>
								<h4 id="theme-status-title">日间模式</h4>
								<p id="theme-status-desc">落樱漫舞的清晨</p>
							</div>
							
							<!-- Tech Stack Tags Widget -->
							<div class="glass-card tech-widget w-50">
								<span class="tech-badge">Astro 7.0</span>
								<span class="tech-badge">Vite 6.0</span>
								<span class="tech-badge">React 19</span>
								<span class="tech-badge">Tailwind 4</span>
								<span class="tech-badge">TypeScript</span>
								<span class="tech-badge">Glassmorphism</span>
							</div>
						</div>
					</div>
				</div>

				<!-- Row 4: Status / Footer info bar -->
				<div class="glass-card footer-bar w-100">
					<div class="footer-left">
						<div class="clock-wrapper">
							<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 2px;">
								<circle cx="12" cy="12" r="10"></circle>
								<polyline points="12 6 12 12 16 14"></polyline>
							</svg>
							<span id="live-clock">12:00:00</span>
						</div>
						<div class="runtime-wrapper">
							<span class="status-pulse"></span>
							<span>系统已稳定运行：<span id="runtime-counter">9天 11小时</span></span>
						</div>
					</div>
					<div class="footer-right">
						<div class="tech-badges-list">
							<span class="tech-badge-pill astro-pill">
								<span class="dot-indicator" style="background-color: #ff5e00;"></span>
								Astro 7.0
							</span>
							<span class="tech-badge-pill vite-pill">
								<span class="dot-indicator" style="background-color: #747bff;"></span>
								Vite 6.0
							</span>
							<span class="tech-badge-pill react-pill">
								<span class="dot-indicator" style="background-color: #38bdf8;"></span>
								React 19
							</span>
						</div>
						<a href="https://icp.gov.cn" target="_blank" class="icp-link">萌ICP备 20260240号</a>
					</div>
				</div>

			</div>
		</main>
		<Footer />

		<!-- Scripts for clock, status, lyrics, and theme states -->
		<script define:vars={{ CURRENT_LOCATION }}>
			// 1. Typing Lyric Effect
			const lyrics = [
				"独有南山桂花发，飞来飞去袭人裾。",
				"曾经沧海难为水，除却巫山不是云。",
				"取次花丛懒回顾，半缘修道半缘君。"
			];
			let lyricIndex = 0;
			const lyricEl = document.getElementById('typing-lyric');
			
			setInterval(() => {
				lyricIndex = (lyricIndex + 1) % lyrics.length;
				if (lyricEl) lyricEl.textContent = lyrics[lyricIndex];
			}, 6000);

			// 2. Live Clock
			const clockEl = document.getElementById('live-clock');
			const updateClock = () => {
				const now = new Date();
				const hours = String(now.getHours()).padStart(2, '0');
				const minutes = String(now.getMinutes()).padStart(2, '0');
				const seconds = String(now.getSeconds()).padStart(2, '0');
				if (clockEl) clockEl.textContent = `${hours}:${minutes}:${seconds}`;
			};
			setInterval(updateClock, 1000);
			updateClock();

			// 3. Dynamic Theme Widget Status Update
			const themeTitle = document.getElementById('theme-status-title');
			const themeDesc = document.getElementById('theme-status-desc');

			const updateThemeWidget = () => {
				const isDark = document.documentElement.getAttribute('data-theme') === 'dark' ||
					(!document.documentElement.getAttribute('data-theme') && window.matchMedia('(prefers-color-scheme: dark)').matches);
				
				if (themeTitle && themeDesc) {
					if (isDark) {
						themeTitle.textContent = "夜间模式";
						themeDesc.textContent = "极光流溢的深夜";
					} else {
						themeTitle.textContent = "日间模式";
						themeDesc.textContent = "落樱漫舞的清晨";
					}
				}
			};

			// Listen for theme mutations
			const observer = new MutationObserver(updateThemeWidget);
			observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
			
			// Initial check
			updateThemeWidget();

			// 4. SVG World Map - Move city marker and dynamically render dot matrix
			(async () => {
				const svgMapContainer = document.getElementById('world-map-svg');
				const cityDot = document.getElementById('city-dot');
				const cityRing = document.getElementById('city-ring');
				const locationDisplay = document.getElementById('current-location-display');
				const pathsGroup = document.getElementById('map-paths-group');
				const gridGroup = document.getElementById('dot-grid-group');
				const cityMarkerGroup = document.getElementById('city-marker-group');

				const CITIES_RELATIVE = {
					Beijing:        { country: 'cn', rx: 0.70, ry: 0.20, label: "Beijing" },
					Shanghai:       { country: 'cn', rx: 0.85, ry: 0.50, label: "Shanghai" },
					Shenzhen:       { country: 'cn', rx: 0.68, ry: 0.75, label: "Shenzhen" },
					Chengdu:        { country: 'cn', rx: 0.38, ry: 0.65, label: "Chengdu" },
					Xian:           { xFallback: 800, yFallback: 215, country: 'cn', rx: 0.52, ry: 0.48, label: "Xi'an" },
					Wuxi:           { country: 'cn', rx: 0.81, ry: 0.50, label: "Wuxi" },
					Tokyo:          { country: 'jp', rx: 0.50, ry: 0.50, label: "Tokyo" },
					Singapore:      { country: 'sg', rx: 0.50, ry: 0.50, label: "Singapore" },
					London:         { country: 'gb', rx: 0.40, ry: 0.80, label: "London" },
					Paris:          { country: 'fr', rx: 0.45, ry: 0.45, label: "Paris" },
					"New York":     { country: 'us', rx: 0.88, ry: 0.35, label: "New York" },
					"San Francisco":{ country: 'us', rx: 0.08, ry: 0.38, label: "San Francisco" },
					Sydney:         { country: 'au', rx: 0.85, ry: 0.78, label: "Sydney" }
				};

				const cityKey = CURRENT_LOCATION || 'Xian';
				const cityData = CITIES_RELATIVE[cityKey] || CITIES_RELATIVE.Xian;

				try {
					const { default: worldMap } = await import('https://unpkg.com/@svg-maps/world@2.0.0/index.js');
					if (!svgMapContainer || !pathsGroup || !gridGroup) return;

					// 1. Append the high-fidelity country paths to the invisible group
					worldMap.locations.forEach(loc => {
						const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
						path.setAttribute('d', loc.path);
						path.setAttribute('id', loc.id);
						path.classList.add('country-path');
						pathsGroup.appendChild(path);
					});

					// 2. Position the city marker using relative bounding box offsets
					const countryPath = svgMapContainer.querySelector(`path[id="${cityData.country}"]`);
					let markerX = cityData.xFallback || 800;
					let markerY = cityData.yFallback || 215;

					if (countryPath) {
						const bbox = countryPath.getBBox();
						markerX = bbox.x + bbox.width * cityData.rx;
						markerY = bbox.y + bbox.height * cityData.ry;
					}

					if (cityDot && cityRing) {
						cityDot.setAttribute('cx', markerX);
						cityDot.setAttribute('cy', markerY);
						cityRing.setAttribute('cx', markerX);
						cityRing.setAttribute('cy', markerY);
						if (cityMarkerGroup) cityMarkerGroup.style.display = 'block';
					}
					if (locationDisplay) {
						locationDisplay.textContent = cityData.label;
					}

					// 3. Zoom and Center the viewBox on the city marker, clamping within map bounds [0, 1010] and [25, 525]
					const zoomH = 200;
					const zoomW = 410; // Aspect ratio of ~2.05 to fit the wrapper nicely
					const minX = Math.max(0, Math.min(1010 - zoomW, markerX - zoomW / 2));
					const minY = Math.max(25, Math.min(525 - zoomH, markerY - zoomH / 2));

					svgMapContainer.setAttribute('viewBox', `${minX} ${minY} ${zoomW} ${zoomH}`);

					// 4. Sample a dense grid of dots only over the visible zoomed-in viewBox
					const cols = 80;
					const rows = 40;
					const lands = pathsGroup.querySelectorAll('.country-path');
					const pt = svgMapContainer.createSVGPoint();

					// Pre-calculate country bounding boxes to optimize sampling performance
					const countryBBoxes = Array.from(lands).map(path => ({
						path: path,
						bbox: path.getBBox()
					}));

					for (let r = 0; r < rows; r++) {
						for (let c = 0; c < cols; c++) {
							const cx = minX + (c + 0.5) * (zoomW / cols);
							const cy = minY + (r + 0.5) * (zoomH / rows);

							pt.x = cx;
							pt.y = cy;

							let isLand = false;
							// BBox pre-filtering optimization to bypass heavy isPointInFill calls for ocean cells
							for (let i = 0; i < countryBBoxes.length; i++) {
								const { path, bbox } = countryBBoxes[i];
								if (cx >= bbox.x && cx <= bbox.x + bbox.width &&
									cy >= bbox.y && cy <= bbox.y + bbox.height) {
									if (path.isPointInFill(pt)) {
										isLand = true;
										break;
									}
								}
							}

							const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
							circle.setAttribute('cx', cx);
							circle.setAttribute('cy', cy);
							circle.setAttribute('r', '1.5'); // Shrunk dot radius for high-resolution detail at zoom level
							circle.classList.add('map-dot');
							if (isLand) {
								circle.classList.add('active-land');
							}
							gridGroup.appendChild(circle);
						}
					}
				} catch (err) {
					console.error('Error rendering high-fidelity dot-matrix map:', err);
				}
			})();
		</script>
	</body>
</html>
