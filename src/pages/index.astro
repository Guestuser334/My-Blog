---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, CURRENT_LOCATION } from '../consts';

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 3);
const latestPost = posts[0];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.widget-grid {
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
				padding: 1.5rem 0;
			}
			.row-flex {
				display: flex;
				gap: 1.5rem;
			}
			.w-60 { width: 60%; }
			.w-40 { width: 40%; }
			.w-35 { width: 35%; }
			.w-65 { width: 65%; }
			.w-100 { width: 100%; }

			/* Search Widget */
			.search-widget {
				padding: 1rem 1.5rem;
			}
			.search-inner {
				display: flex;
				align-items: center;
				gap: 0.8rem;
				color: var(--text-muted);
				font-size: 1.05rem;
				cursor: text;
			}
			.search-inner svg {
				opacity: 0.6;
			}

			/* Profile Card */
			.profile-card {
				display: flex;
				flex-direction: column;
				justify-content: space-between;
				height: 250px;
			}
			.profile-top {
				display: flex;
				gap: 1.5rem;
				align-items: center;
			}
			.profile-avatar {
				width: 80px;
				height: 80px;
				border-radius: 20px;
				object-fit: cover;
				border: 2px solid var(--glass-border);
				box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
			}
			.profile-info h2 {
				margin: 0 0 0.3rem 0;
				font-size: 1.7rem;
				font-weight: 800;
				letter-spacing: -0.02em;
			}
			.profile-info p {
				margin: 0;
				font-size: 1rem;
				color: var(--text-muted);
				line-height: 1.5;
			}
			.profile-bottom {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-top: 1rem;
			}
			.profile-stats {
				display: flex;
				gap: 1.5rem;
			}
			.stat-item {
				text-align: center;
			}
			.stat-val {
				font-size: 1.45rem;
				font-weight: 800;
				color: var(--accent);
				display: block;
			}
			.stat-lbl {
				font-size: 0.85rem;
				color: var(--text-muted);
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}
			.profile-socials {
				display: flex;
				gap: 0.6rem;
			}
			.social-btn {
				width: 38px;
				height: 38px;
				border-radius: 50%;
				background: rgba(var(--accent-color), 0.05);
				border: 1px solid rgba(var(--accent-color), 0.1);
				display: flex;
				align-items: center;
				justify-content: center;
				color: var(--text-color);
				transition: all 0.2s;
			}
			.social-btn:hover {
				background: var(--accent);
				color: white !important;
				transform: translateY(-2px);
				box-shadow: 0 4px 12px rgba(var(--accent-color), 0.35);
			}

			/* Map Widget - Obsidian Contrast Design */
			.map-widget {
				height: 250px;
				display: flex;
				flex-direction: column;
				justify-content: space-between;
				position: relative;
				overflow: hidden;
				background: rgba(18, 18, 24, 0.93) !important;
				border: 1px solid rgba(255, 255, 255, 0.12) !important;
				box-shadow: 0 10px 30px 0 rgba(0, 0, 0, 0.3) !important;
				color: #f5f5f7 !important;
			}
			.map-header h3 {
				margin: 0;
				font-size: 1.05rem;
				color: #ffffff;
			}
			.map-title-wrapper {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				color: #ffffff;
			}

			/* SVG Map */
			.svg-map-wrapper {
				flex-grow: 1;
				position: relative;
				overflow: hidden;
				margin: 0.2rem 0;
			}
			.svg-map-wrapper svg {
				width: 100%;
				height: 100%;
			}
			.map-land {
				fill: none;
				stroke: none;
			}
			:global(.map-dot) {
				fill: rgba(255, 255, 255, 0.08);
				transition: fill 0.3s;
			}
			:global(.map-dot.active-land) {
				fill: var(--accent) !important;
				opacity: 0.95;
			}
			.city-marker {
				fill: #10b981;
				filter: drop-shadow(0 0 6px #10b981);
				animation: pulse-city 2s infinite;
			}
			.city-ring {
				fill: none;
				stroke: #10b981;
				stroke-width: 1.2;
				animation: expand-ring 2s infinite;
				transform-box: fill-box;
				transform-origin: center;
			}
			@keyframes pulse-city {
				0%, 100% { opacity: 1; r: 5; }
				50% { opacity: 0.7; r: 7; }
			}
			@keyframes expand-ring {
				0% { transform: scale(1); opacity: 0.8; }
				100% { transform: scale(3.5); opacity: 0; }
			}

			.location-footer {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				font-size: 0.85rem;
				border-top: 1px solid rgba(255, 255, 255, 0.08);
				padding-top: 0.4rem;
			}
			.location-dot-pulse {
				width: 8px;
				height: 8px;
				border-radius: 50%;
				background-color: #10b981;
				box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
				animation: pulse 2s infinite;
			}
			.location-text {
				color: rgba(255, 255, 255, 0.75);
			}
			.location-text strong {
				color: var(--accent);
			}

			/* Status Banner / Lyric Marquee */
			.status-banner {
				padding: 0.8rem 1.5rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
				font-size: 0.95rem;
				overflow: hidden;
			}
			.lyric-text {
				font-weight: 700;
				color: var(--accent);
				text-shadow: 0 1px 3px rgba(255, 255, 255, 0.85);
			}
			:root[data-theme="dark"] .lyric-text {
				text-shadow: 0 0 10px rgba(var(--accent-color), 0.4);
			}
			@media (prefers-color-scheme: dark) {
				:root:not([data-theme="light"]) .lyric-text {
					text-shadow: 0 0 10px rgba(var(--accent-color), 0.4);
				}
			}

			/* Featured Post Card */
			.featured-widget {
				display: flex;
				flex-direction: column;
				gap: 1rem;
				justify-content: space-between;
				color: inherit;
				text-decoration: none;
			}
			.featured-tag {
				font-size: 0.7rem;
				font-weight: 800;
				color: white;
				background: linear-gradient(135deg, var(--accent), #f43f5e);
				padding: 3px 8px;
				border-radius: 6px;
				align-self: flex-start;
				letter-spacing: 0.05em;
				text-transform: uppercase;
			}
			.featured-img {
				width: 100%;
				height: 160px;
				object-fit: cover;
				border-radius: 14px;
				border: 1px solid var(--glass-border);
			}
			.featured-widget h3 {
				margin: 0;
				font-size: 1.35rem;
				line-height: 1.3;
				color: var(--text-color);
				transition: color 0.2s;
			}
			.featured-widget:hover h3 {
				color: var(--accent);
			}
			.featured-widget p {
				font-size: 0.95rem;
				color: var(--text-muted);
				margin: 0;
				line-height: 1.5;
				display: -webkit-box;
				-webkit-line-clamp: 3;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.featured-bottom {
				display: flex;
				justify-content: space-between;
				align-items: center;
				font-size: 0.9rem;
				color: var(--text-muted);
				margin-top: 0.5rem;
			}

			/* Right Grid Section (Posts List + Theme Widget) */
			.right-content-grid {
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
				height: 100%;
			}
			
			/* Recent Posts Widget */
			.recent-posts-widget {
				flex-grow: 1;
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}
			.widget-title {
				font-size: 1.25rem;
				font-weight: 800;
				margin: 0 0 0.5rem 0;
				display: flex;
				align-items: center;
				gap: 0.5rem;
			}
			.post-row {
				display: flex;
				justify-content: space-between;
				align-items: center;
				padding: 0.6rem 0.8rem;
				border-radius: 12px;
				transition: background-color 0.2s, transform 0.2s;
			}
			.post-row:hover {
				background: rgba(var(--accent-color), 0.05);
				transform: translateX(4px);
			}
			.post-title-link {
				color: var(--text-color);
				font-weight: 600;
				font-size: 1.05rem;
				white-space: nowrap;
				overflow: hidden;
				text-overflow: ellipsis;
				max-width: 70%;
			}
			.post-row:hover .post-title-link {
				color: var(--accent);
			}
			.post-meta-tag {
				font-size: 0.9rem;
				color: var(--text-muted);
			}

			/* Bottom sub-row */
			.sub-row {
				display: flex;
				gap: 1.5rem;
			}
			.w-50 { width: 50%; }

			/* Theme Widget */
			.theme-widget {
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				text-align: center;
				padding: 1.5rem 1rem;
				position: relative;
			}
			.theme-circle {
				width: 50px;
				height: 50px;
				border-radius: 50%;
				background: linear-gradient(135deg, #00f2fe 0%, #4facfe 100%);
				box-shadow: 0 4px 15px rgba(79, 172, 254, 0.4);
				margin-bottom: 0.8rem;
				animation: spin 8s linear infinite;
			}
			:root[data-theme="dark"] .theme-circle {
				background: linear-gradient(135deg, #f39c12 0%, #f1c40f 100%);
				box-shadow: 0 4px 15px rgba(241, 196, 15, 0.4);
			}
			@media (prefers-color-scheme: dark) {
				:root:not([data-theme="light"]) .theme-circle {
					background: linear-gradient(135deg, #f39c12 0%, #f1c40f 100%);
					box-shadow: 0 4px 15px rgba(241, 196, 15, 0.4);
				}
			}
			.theme-widget h4 {
				margin: 0 0 0.2rem 0;
				font-size: 1.08rem;
				font-weight: 700;
			}
			.theme-widget p {
				margin: 0;
				font-size: 0.85rem;
				color: var(--text-muted);
			}

			/* Tech Stack Widget */
			.tech-widget {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				align-content: center;
				justify-content: center;
				padding: 1.2rem;
			}
			.tech-badge {
				font-size: 0.85rem;
				padding: 5px 10px;
				border-radius: 8px;
				background: rgba(255, 255, 255, 0.15);
				border: 1px solid var(--glass-border);
				color: var(--text-color);
				font-weight: 600;
			}
			:root[data-theme="dark"] .tech-badge {
				background: rgba(0, 0, 0, 0.25);
			}
			@media (prefers-color-scheme: dark) {
				:root:not([data-theme="light"]) .tech-badge {
					background: rgba(0, 0, 0, 0.25);
				}
			}

			/* Status / Footer bar */
			/* Status / Footer bar */
			.footer-bar {
				padding: 1rem 2rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
				font-size: 0.9rem;
				color: var(--text-color);
			}
			
			.footer-left {
				display: flex;
				align-items: center;
				gap: 1.2rem;
			}
			.clock-wrapper {
				display: flex;
				align-items: center;
				gap: 0.4rem;
				background: rgba(124, 58, 237, 0.08);
				border: 1px solid rgba(124, 58, 237, 0.15);
				padding: 0.3rem 0.8rem;
				border-radius: 12px;
				font-weight: 700;
				color: rgb(124, 58, 237);
				font-variant-numeric: tabular-nums;
				text-shadow: 0 1px 2px rgba(255, 255, 255, 0.5);
			}
			:root[data-theme="dark"] .clock-wrapper {
				background: rgba(167, 139, 250, 0.12);
				border-color: rgba(167, 139, 250, 0.22);
				color: rgb(167, 139, 250);
				text-shadow: none;
			}
			@media (prefers-color-scheme: dark) {
				:root:not([data-theme="light"]) .clock-wrapper {
					background: rgba(167, 139, 250, 0.12);
					border-color: rgba(167, 139, 250, 0.22);
					color: rgb(167, 139, 250);
					text-shadow: none;
				}
			}
			
			.runtime-wrapper {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				font-size: 0.85rem;
				color: var(--text-muted);
			}
			.status-pulse {
				width: 8px;
				height: 8px;
				border-radius: 50%;
				background-color: #10b981;
				box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
				animation: pulse 2s infinite;
			}
			@keyframes pulse {
				0% {
					transform: scale(0.95);
					box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
				}
				70% {
					transform: scale(1);
					box-shadow: 0 0 0 6px rgba(16, 185, 129, 0);
				}
				100% {
					transform: scale(0.95);
					box-shadow: 0 0 0 0 rgba(16, 185, 129, 0);
				}
			}

			.footer-right {
				display: flex;
				align-items: center;
				gap: 1.5rem;
			}
			.tech-badges-list {
				display: flex;
				gap: 0.5rem;
			}
			.tech-badge-pill {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				padding: 0.2rem 0.6rem;
				border-radius: 8px;
				font-size: 0.75rem;
				font-weight: 600;
				border: 1px solid rgba(var(--accent-color), 0.15);
				background: rgba(var(--accent-color), 0.05);
				color: var(--text-color);
				transition: transform 0.2s, background-color 0.2s;
			}
			.tech-badge-pill:hover {
				transform: translateY(-1px);
			}
			.tech-badge-pill .dot-indicator {
				width: 6px;
				height: 6px;
				border-radius: 50%;
			}
			.tech-badge-pill.astro-pill {
				border-color: rgba(255, 94, 0, 0.2);
				background: rgba(255, 94, 0, 0.08);
				color: #e65c00;
			}
			:root[data-theme="dark"] .tech-badge-pill.astro-pill {
				color: #ff8533;
			}
			.tech-badge-pill.vite-pill {
				border-color: rgba(100, 108, 255, 0.2);
				background: rgba(100, 108, 255, 0.08);
				color: #4f46e5;
			}
			:root[data-theme="dark"] .tech-badge-pill.vite-pill {
				color: #818cf8;
			}
			.tech-badge-pill.react-pill {
				border-color: rgba(8, 126, 164, 0.2);
				background: rgba(8, 126, 164, 0.08);
				color: #087ea4;
			}
			:root[data-theme="dark"] .tech-badge-pill.react-pill {
				color: #22d3ee;
			}
			.icp-link {
				font-size: 0.8rem;
				color: var(--text-muted);
				transition: color 0.2s;
			}
			.icp-link:hover {
				color: var(--accent);
			}

			/* Keyframes */
			@keyframes spin {
				from { transform: rotate(0deg); }
				to { transform: rotate(360deg); }
			}
			@keyframes blink {
				from, to { border-color: transparent }
				50% { border-color: var(--accent); }
			}

			/* Responsive styling */
			@media (max-width: 768px) {
				.row-flex {
					flex-direction: column;
					gap: 1rem;
				}
				.w-60, .w-40, .w-35, .w-65, .w-50 {
					width: 100% !important;
				}
				.profile-card, .map-widget {
					height: auto;
				}
				.sub-row {
					flex-direction: column;
					gap: 1rem;
				}
				.footer-bar {
					flex-direction: column;
					gap: 0.5rem;
					text-align: center;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="widget-grid">
				
				<!-- Search / Welcome Bar -->
				<div class="glass-card search-widget">
					<div class="search-inner">
						<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
							<circle cx="11" cy="11" r="8"></circle>
							<line x1="21" y1="21" x2="16.65" y2="16.65"></line>
						</svg>
						<span>搜索文章标题或正文内容...</span>
					</div>
				</div>

				<!-- Row 1: Profile + Music Player -->
				<div class="row-flex">
					<!-- Profile Card -->
					<div class="glass-card profile-card w-60">
						<div class="profile-top">
							<img src="https://images.unsplash.com/photo-1534528741775-53994a69daeb?q=80&w=150&auto=format&fit=crop" alt="Avatar" class="profile-avatar" />
							<div class="profile-info">
								<h2>Hi, I'm Skittles!</h2>
								<p>Grade 2024 student in EE, Xi'an Jiaotong University<br />
								   Designing quantitative trading based on power grids<br />
								   I am learning everything I found interesting<br />
								</p>
							</div>
						</div>
						<div class="profile-bottom">
							<div class="profile-stats">
								<div class="stat-item">
									<span class="stat-val">{allPosts.length}</span>
									<span class="stat-lbl">文章</span>
								</div>
								<div class="stat-item">
									<span class="stat-val">3</span>
									<span class="stat-lbl">分类</span>
								</div>
								<div class="stat-item">
									<span class="stat-val">12</span>
									<span class="stat-lbl">标签</span>
								</div>
							</div>
							<div class="profile-socials">
								<a href="https://github.com/withastro/astro" target="_blank" class="social-btn" aria-label="GitHub">
									<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
									</svg>
								</a>
								<a href="#" class="social-btn" aria-label="WeChat">
									<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
									</svg>
								</a>
								<a href="mailto:example@example.com" class="social-btn" aria-label="Mail">
									<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
										<polyline points="22,6 12,13 2,6"></polyline>
									</svg>
								</a>
							</div>
						</div>
					</div>

					<!-- Interactive Location Map Card - SVG based -->
					<div class="glass-card map-widget w-40">
						<div class="map-header">
							<div class="map-title-wrapper">
								<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<circle cx="12" cy="12" r="10"></circle>
									<line x1="2" y1="12" x2="22" y2="12"></line>
									<path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
								</svg>
								<h3>我的足迹与定位</h3>
							</div>
						</div>

						<!-- SVG World Map -->
						<div class="svg-map-wrapper">
