---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, CURRENT_LOCATION } from '../consts';
import avatarImage from '../assets/avatar.png';

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 3);
const latestPost = posts[0];

const formatDate = (date: Date) => {
	const d = new Date(date);
	const y = d.getFullYear();
	const m = String(d.getMonth() + 1).padStart(2, '0');
	const day = String(d.getDate()).padStart(2, '0');
	return `${y}/${m}/${day}`;
};

const formatDateSpaced = (date: Date) => {
	const d = new Date(date);
	const y = d.getFullYear();
	const m = String(d.getMonth() + 1).padStart(2, '0');
	const day = String(d.getDate()).padStart(2, '0');
	return `${y} / ${m} / ${day}`;
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.widget-grid {
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
				padding: 1.5rem 0;
			}
			.row-flex {
				display: flex;
				gap: 1.5rem;
			}
			.w-60 { width: 60%; }
			.w-40 { width: 40%; }
			.w-35 { width: 35%; }
			.w-65 { width: 65%; }
			.w-100 { width: 100%; }

			/* Search Widget */
			.search-widget {
				padding: 1rem 1.5rem;
			}
			.search-inner {
				display: flex;
				align-items: center;
				gap: 0.8rem;
				color: rgba(255, 255, 255, 0.75); /* High contrast readable color */
				font-size: 1.05rem;
				cursor: text;
			}
			.search-inner svg {
				opacity: 0.85; /* Brighten icon */
			}

			/* Profile Card */
			.profile-card {
				display: flex;
				flex-direction: column;
				justify-content: space-between;
				height: 250px;
				position: relative;
				top: 0;
				/* Hover animation defined via top property, shadow inherits from global */
				transition: top 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s ease;
			}
			
			.profile-card:hover {
				top: -4px;
				/* Add an accent shadow glow on hover on top of the global hover shadow */
				box-shadow: 
					inset 0 1px 1.5px rgba(255, 255, 255, 0.5),
					0 16px 40px rgba(0, 0, 0, 0.15), 
					0 0 1px 1px rgba(var(--accent-color), 0.3);
			}
			.profile-title-link {
				color: inherit;
				text-decoration: none;
				outline: none;
			}
			.profile-title-link::after {
				content: '';
				position: absolute;
				top: 0;
				left: 0;
				right: 0;
				bottom: 0;
				z-index: 1;
				border-radius: 24px;
			}
			.profile-top {
				display: flex;
				gap: 1.5rem;
				align-items: center;
			}
			.profile-avatar {
				width: 80px;
				height: 80px;
				border-radius: 20px;
				object-fit: cover;
				border: 2px solid var(--glass-border);
				box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
			}
			.profile-info h2 {
				margin: 0 0 0.3rem 0;
				font-size: 1.7rem;
				font-weight: 800;
				letter-spacing: -0.02em;
			}
			.profile-info p {
				margin: 0;
				font-size: 1rem;
				color: var(--text-color);
				line-height: 1.5;
			}
			.profile-bottom {
				display: flex;
				justify-content: space-between;
				align-items: center;
				margin-top: 1rem;
			}
			.profile-stats {
				display: flex;
				gap: 1.5rem;
			}
			.stat-item {
				text-align: center;
			}
			.stat-val {
				font-size: 1.45rem;
				font-weight: 800;
				color: var(--accent);
				display: block;
			}
			.stat-lbl {
				font-size: 0.85rem;
				color: var(--text-muted);
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}
			.profile-socials {
				display: flex;
				gap: 0.6rem;
				position: relative;
				z-index: 2;
			}
			.social-btn {
				width: 38px;
				height: 38px;
				border-radius: 50%;
				background: rgba(var(--accent-color), 0.05);
				border: 1px solid rgba(var(--accent-color), 0.1);
				display: flex;
				align-items: center;
				justify-content: center;
				color: var(--text-color);
				transition: all 0.2s;
			}
			.social-btn:hover {
				background: var(--accent);
				color: white !important;
				transform: translateY(-2px);
				box-shadow: 0 4px 12px rgba(var(--accent-color), 0.35);
			}

			/* Map Widget - Obsidian Contrast Design */
			.map-widget {
				height: 250px;
				display: flex;
				flex-direction: column;
				justify-content: space-between;
				position: relative;
				overflow: hidden;
				/* Frosted Black Glass styling */
				background-color: rgba(12, 12, 16, 0.15); /* MUCH MORE transparent */
				background-clip: padding-box; /* Forces background to stop exactly inside the border */
				backdrop-filter: blur(12px);
			}
			.map-header h3 {
				margin: 0;
				font-size: 1.05rem;
				color: #ffffff;
			}
			.map-title-wrapper {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				color: #ffffff;
			}

			/* SVG Map */
			.svg-map-wrapper {
				flex-grow: 1;
				position: relative;
				overflow: hidden;
				margin: 0.2rem 0;
			}
			.svg-map-wrapper svg {
				width: 100%;
				height: 100%;
			}
			.map-land {
				display: none;
			}
			:global(.country-path) {
				fill: none !important;
				stroke: none !important;
				pointer-events: none !important;
			}
			:global(.map-dot) {
				fill: rgba(255, 255, 255, 0.12); /* Brighter ocean dots */
				transition: fill 0.3s;
			}
			:global(.map-dot.active-land) {
				fill: var(--accent) !important;
				opacity: 0.95;
			}
			.city-marker {
				fill: #10b981;
				filter: drop-shadow(0 0 4px #10b981);
				animation: pulse-city 2s infinite;
			}
			.city-ring {
				fill: none;
				stroke: #10b981;
				stroke-width: 0.6;
				animation: expand-ring 2s infinite;
				transform-box: fill-box;
				transform-origin: center;
			}
			@keyframes pulse-city {
				0%, 100% { opacity: 1; r: 2.2; }
				50% { opacity: 0.7; r: 3.5; }
			}
			@keyframes expand-ring {
				0% { transform: scale(1); opacity: 0.8; }
				100% { transform: scale(3.5); opacity: 0; }
			}

			.location-footer {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				font-size: 0.85rem;
				border-top: 1px solid rgba(255, 255, 255, 0.08);
				padding-top: 0.4rem;
			}
			.location-dot-pulse {
				width: 8px;
				height: 8px;
				border-radius: 50%;
				background-color: #10b981;
				box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
				animation: pulse 2s infinite;
			}
			.location-text {
				color: rgba(255, 255, 255, 0.75);
			}
			.location-text strong {
				color: var(--accent);
			}

			/* Status Banner / Lyric Marquee */
			.status-banner {
				padding: 0.8rem 1.5rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
				font-size: 0.95rem;
				overflow: hidden;
			}
			.lyric-text {
				font-weight: 700;
				color: var(--accent);
				text-shadow: 0 1px 3px rgba(255, 255, 255, 0.85);
			}
			:root[data-theme="dark"] .lyric-text {
				text-shadow: 0 0 10px rgba(var(--accent-color), 0.4);
			}
			@media (prefers-color-scheme: dark) {
				:root:not([data-theme="light"]) .lyric-text {
					text-shadow: 0 0 10px rgba(var(--accent-color), 0.4);
				}
			}

			/* Featured Post Card */
			.featured-widget {
				display: flex;
				flex-direction: column;
				gap: 1rem;
				justify-content: space-between;
				color: inherit;
				text-decoration: none;
			}
			.featured-tag {
				font-size: 0.7rem;
				font-weight: 800;
				color: white;
				background: linear-gradient(135deg, var(--accent), #f43f5e);
				padding: 3px 8px;
				border-radius: 6px;
				align-self: flex-start;
				letter-spacing: 0.05em;
				text-transform: uppercase;
			}
			.featured-img {
				width: 100%;
				height: 160px;
				object-fit: cover;
				border-radius: 14px;
				border: 1px solid var(--glass-border);
			}
			.featured-widget h3 {
				margin: 0;
				font-size: 1.35rem;
				line-height: 1.3;
				color: var(--text-color);
				transition: color 0.2s;
			}
			.featured-widget:hover h3 {
				color: var(--accent);
			}
			.featured-widget p {
				font-size: 0.95rem;
				color: var(--text-muted);
				margin: 0;
				line-height: 1.5;
				display: -webkit-box;
				-webkit-line-clamp: 3;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.featured-bottom {
				display: flex;
				justify-content: space-between;
				align-items: center;
				font-size: 0.9rem;
				color: var(--text-muted);
				margin-top: 0.5rem;
			}

			/* Right Grid Section (Posts List + Theme Widget) */
			.right-content-grid {
				display: flex;
				flex-direction: column;
				gap: 1.5rem;
				height: 100%;
			}
			
			/* Recent Posts Widget */
			.recent-posts-widget {
				flex-grow: 1;
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}
			.widget-title {
				font-size: 1.25rem;
				font-weight: 800;
				margin: 0 0 0.5rem 0;
				display: flex;
				align-items: center;
				gap: 0.5rem;
			}
			.post-row {
				display: flex;
				justify-content: space-between;
				align-items: center;
				padding: 0.6rem 0.8rem;
				border-radius: 12px;
				transition: background-color 0.2s, transform 0.2s;
			}
			.post-row:hover {
				background: rgba(var(--accent-color), 0.05);
				transform: translateX(4px);
			}
			.post-title-link {
				color: var(--text-color);
				font-weight: 600;
				font-size: 1.05rem;
				white-space: nowrap;
				overflow: hidden;
				text-overflow: ellipsis;
				max-width: 70%;
			}
			.post-row:hover .post-title-link {
				color: var(--accent);
			}
			.post-meta-tag {
				font-size: 0.9rem;
				color: var(--text-muted);
			}

			/* Bottom sub-row */
			.sub-row {
				display: flex;
				gap: 1.5rem;
			}
			.w-50 { width: 50%; }

			/* Theme Widget */
			.theme-widget {
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				text-align: center;
				padding: 1.5rem 1rem;
				position: relative;
			}

			/* Theme Widget Icon (Sun & Moon) */
			.theme-circle {
				width: 50px;
				height: 50px;
				border-radius: 50%;
				display: flex;
				align-items: center;
				justify-content: center;
				background: linear-gradient(135deg, #ff5e62 0%, #ff9966 100%);
				box-shadow: 0 4px 15px rgba(255, 94, 98, 0.45);
				margin-bottom: 0.8rem;
				color: white;
				transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
			}
			.theme-circle .sun-svg {
				width: 24px;
				height: 24px;
				display: block;
				animation: spin 20s linear infinite;
			}
			.theme-circle .moon-svg {
				width: 22px;
				height: 22px;
				display: none;
			}
			.theme-widget:hover .theme-circle {
				transform: scale(1.1);
				box-shadow: 0 6px 20px rgba(255, 94, 98, 0.6);
			}
			
			/* Dark Mode styling */
			:root[data-theme="dark"] .theme-circle {
				background: linear-gradient(135deg, #f39c12 0%, #f1c40f 100%);
				box-shadow: 0 4px 15px rgba(241, 196, 15, 0.4);
			}
			:root[data-theme="dark"] .theme-circle .sun-svg {
				display: none;
			}
			:root[data-theme="dark"] .theme-circle .moon-svg {
				display: block;
				color: white;
				animation: float-moon 3s ease-in-out infinite;
			}
			:root[data-theme="dark"] .theme-widget:hover .theme-circle {
				box-shadow: 0 6px 20px rgba(241, 196, 15, 0.6);
			}
			@media (prefers-color-scheme: dark) {
				:root:not([data-theme="light"]) .theme-circle {
					background: linear-gradient(135deg, #f39c12 0%, #f1c40f 100%);
					box-shadow: 0 4px 15px rgba(241, 196, 15, 0.4);
				}
				:root:not([data-theme="light"]) .theme-circle .sun-svg {
					display: none;
				}
				:root:not([data-theme="light"]) .theme-circle .moon-svg {
					display: block;
					color: white;
					animation: float-moon 3s ease-in-out infinite;
				}
				:root:not([data-theme="light"]) .theme-widget:hover .theme-circle {
					box-shadow: 0 6px 20px rgba(241, 196, 15, 0.6);
				}
			}
			@keyframes float-moon {
				0%, 100% { transform: translateY(0); }
				50% { transform: translateY(-2px); }
			}

			.theme-widget h4 {
				margin: 0 0 0.2rem 0;
				font-size: 1.08rem;
				font-weight: 700;
			}
			.theme-widget p {
				margin: 0;
				font-size: 0.85rem;
				color: var(--text-muted);
			}

			/* Tech Stack Widget */
			.tech-widget {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				align-content: center;
				justify-content: center;
				padding: 1.2rem;
			}
			.tech-badge {
				font-size: 0.85rem;
				padding: 5px 10px;
				border-radius: 8px;
				background: rgba(255, 255, 255, 0.15);
				border: 1px solid var(--glass-border);
				color: var(--text-color);
				font-weight: 600;
			}
			:root[data-theme="dark"] .tech-badge {
				background: rgba(0, 0, 0, 0.25);
			}
			@media (prefers-color-scheme: dark) {
				:root:not([data-theme="light"]) .tech-badge {
					background: rgba(0, 0, 0, 0.25);
				}
			}

			/* Status / Footer bar */
			.footer-bar {
				padding: 1rem 2rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
				font-size: 0.9rem;
				color: var(--text-color);
			}
			
			.footer-left {
				display: flex;
				align-items: center;
				gap: 1.2rem;
			}

			/* Retro Nixie Tube Clock */
			.nixie-clock {
				display: inline-flex;
				align-items: center;
				gap: 4px;
				background: #09090b;
				border: 2px solid rgba(255, 255, 255, 0.05);
				border-radius: 10px;
				padding: 4px 8px;
				box-shadow: inset 0 0 10px rgba(0, 0, 0, 0.95), 0 3px 10px rgba(0, 0, 0, 0.4);
				font-family: 'Courier New', Courier, monospace;
			}
			.nixie-tube {
				position: relative;
				width: 20px;
				height: 34px;
				background: radial-gradient(circle at center, rgba(30, 16, 5, 0.95) 0%, rgba(5, 4, 4, 0.98) 100%);
				border: 1px solid rgba(255, 255, 255, 0.04);
				border-radius: 6px;
				overflow: hidden;
				display: flex;
				align-items: center;
				justify-content: center;
				box-shadow: inset 0 0 5px rgba(0,0,0,0.9);
			}
			.nixie-tube::before {
				content: '';
				position: absolute;
				top: 0;
				left: 0;
				right: 0;
				bottom: 0;
				background-image: 
					linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
					linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
				background-size: 2px 2px;
				z-index: 1;
				pointer-events: none;
			}
			.nixie-num {
				font-size: 1.35rem;
				font-weight: 700;
				color: #ff7700;
				text-shadow: 
					0 0 2px #ff3c00, 
					0 0 6px #ff7700, 
					0 0 12px rgba(255, 119, 0, 0.8);
				z-index: 2;
				position: relative;
				line-height: 1;
			}
			.nixie-colon {
				display: flex;
				align-items: center;
				justify-content: center;
				width: 6px;
			}
			.nixie-dot {
				font-size: 1.2rem;
				font-weight: 800;
				color: #ff7700;
				text-shadow: 
					0 0 2px #ff3c00, 
					0 0 6px #ff7700;
				animation: nixie-blink 1s step-end infinite;
			}
			@keyframes nixie-blink {
				from, to { opacity: 1; }
				50% { opacity: 0.15; }
			}
			
			.runtime-wrapper {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				font-size: 0.85rem;
				color: var(--text-muted);
			}
			.status-pulse {
				width: 8px;
				height: 8px;
				border-radius: 50%;
				background-color: #10b981;
				box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
				animation: pulse 2s infinite;
			}
			@keyframes pulse {
				0% {
					transform: scale(0.95);
					box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
				}
				70% {
					transform: scale(1);
					box-shadow: 0 0 0 6px rgba(16, 185, 129, 0);
				}
				100% {
					transform: scale(0.95);
					box-shadow: 0 0 0 0 rgba(16, 185, 129, 0);
				}
			}

			.footer-right {
				display: flex;
				align-items: center;
				gap: 1.5rem;
			}
			.tech-badges-list {
				display: flex;
				gap: 0.5rem;
			}
			.tech-badge-pill {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				padding: 0.2rem 0.6rem;
				border-radius: 8px;
				font-size: 0.75rem;
				font-weight: 600;
				border: 1px solid rgba(var(--accent-color), 0.15);
				background: rgba(var(--accent-color), 0.05);
				color: var(--text-color);
				transition: transform 0.2s, background-color 0.2s;
			}
			.tech-badge-pill:hover {
				transform: translateY(-1px);
			}
			.tech-badge-pill .dot-indicator {
				width: 6px;
				height: 6px;
				border-radius: 50%;
			}
			.tech-badge-pill.astro-pill {
				border-color: rgba(255, 94, 0, 0.2);
				background: rgba(255, 94, 0, 0.08);
				color: #e65c00;
			}
			:root[data-theme="dark"] .tech-badge-pill.astro-pill {
				color: #ff8533;
			}
			.tech-badge-pill.vite-pill {
				border-color: rgba(100, 108, 255, 0.2);
				background: rgba(100, 108, 255, 0.08);
				color: #4f46e5;
			}
			:root[data-theme="dark"] .tech-badge-pill.vite-pill {
				color: #818cf8;
			}
			.tech-badge-pill.react-pill {
				border-color: rgba(8, 126, 164, 0.2);
				background: rgba(8, 126, 164, 0.08);
				color: #087ea4;
			}
			:root[data-theme="dark"] .tech-badge-pill.react-pill {
				color: #22d3ee;
			}
			.icp-link {
				font-size: 0.8rem;
				color: var(--text-muted);
				transition: color 0.2s;
			}
			.icp-link:hover {
				color: var(--accent);
			}

			/* Keyframes */
			@keyframes spin {
				from { transform: rotate(0deg); }
				to { transform: rotate(360deg); }
			}
			@keyframes blink {
				from, to { border-color: transparent }
				50% { border-color: var(--accent); }
			}

			/* Responsive styling */
			@media (max-width: 768px) {
				.row-flex {
					flex-direction: column;
					gap: 1rem;
				}
				.w-60, .w-40, .w-35, .w-65, .w-50 {
					width: 100% !important;
				}
				.glass-card {
					padding: 1.2rem !important; /* more breathing room on mobile */
				}
				
				/* Profile Card Mobile Optimization */
				.profile-card {
					height: auto !important;
					padding-bottom: 1.5rem !important;
				}
				.profile-top {
					flex-direction: column;
					text-align: center;
					gap: 1rem;
				}
				.profile-avatar {
					margin: 0 auto;
					width: 76px;
					height: 76px;
				}
				.profile-info h2 {
					font-size: 1.5rem;
				}
				.profile-bottom {
					flex-direction: column;
					gap: 1.2rem;
					align-items: center;
					margin-top: 1.5rem;
				}
				.profile-stats {
					width: 100%;
					justify-content: space-around;
					gap: 1rem;
				}
				
				/* Map Card Mobile Optimization */
				.map-widget {
					height: 240px !important;
				}
				
				/* Sub-row / Column Layout Stacking */
				.sub-row {
					flex-direction: column;
					gap: 1rem;
				}
				
				/* Status Banner / Signature Mobile Optimization */
				.status-banner {
					flex-direction: column;
					gap: 0.6rem;
					align-items: center;
					text-align: center;
					padding: 1rem 1.2rem !important;
					font-size: 0.9rem;
				}
				.status-banner > div {
					width: 100%;
				}

				/* Footer Bar Mobile Optimization */
				.footer-bar {
					flex-direction: column;
					gap: 1.2rem;
					text-align: center;
					padding: 1.5rem 1rem !important;
				}
				.footer-left {
					flex-direction: column;
					align-items: center;
					gap: 0.6rem;
				}
				.footer-right {
					flex-direction: column;
					align-items: center;
					gap: 0.8rem;
				}
				.tech-badges-list {
					justify-content: center;
					flex-wrap: wrap;
					gap: 0.4rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="widget-grid">
				
				<!-- Search / Welcome Bar -->
				<div class="glass-card search-widget">
					<div class="search-inner">
						<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
							<circle cx="11" cy="11" r="8"></circle>
							<line x1="21" y1="21" x2="16.65" y2="16.65"></line>
						</svg>
						<span>搜索文章标题或正文内容...</span>
					</div>
				</div>

				<!-- Row 1: Profile + Music Player -->
				<div class="row-flex">
					<!-- Profile Card -->
					<div class="glass-card profile-card w-60">
						<div class="profile-card-noise"></div>
						<div class="profile-top">
							<img src={avatarImage.src} alt="Avatar" class="profile-avatar" />
							<div class="profile-info">
								<h2><a href="/about" class="profile-title-link">Hi, I'm Skittles!</a></h2>
								<p>Grade 2024 student in EE, Xi'an Jiaotong University<br />
								   Designing quantitative trading based on power grids<br />
								   I am learning everything I found interesting<br />
								</p>
							</div>
						</div>
						<div class="profile-bottom">
							<div class="profile-stats">
								<div class="stat-item">
									<span class="stat-val">{allPosts.length}</span>
									<span class="stat-lbl">文章</span>
								</div>
								<div class="stat-item">
									<span class="stat-val">3</span>
									<span class="stat-lbl">分类</span>
								</div>
								<div class="stat-item">
									<span class="stat-val">12</span>
									<span class="stat-lbl">标签</span>
								</div>
							</div>
							<div class="profile-socials">
								<a href="https://github.com/withastro/astro" target="_blank" class="social-btn" aria-label="GitHub">
									<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
									</svg>
								</a>
								<a href="#" class="social-btn" aria-label="WeChat">
									<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
									</svg>
								</a>
								<a href="mailto:example@example.com" class="social-btn" aria-label="Mail">
									<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
										<polyline points="22,6 12,13 2,6"></polyline>
									</svg>
								</a>
							</div>
						</div>
					</div>

					<!-- Interactive Location Map Card - SVG based -->
					<div class="glass-card map-widget w-40">
						<div class="map-header">
							<div class="map-title-wrapper">
								<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<circle cx="12" cy="12" r="10"></circle>
									<line x1="2" y1="12" x2="22" y2="12"></line>
									<path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
								</svg>
								<h3>My location</h3>
							</div>
						</div>

						<!-- SVG World Map -->
						<div class="svg-map-wrapper">
							<svg id="world-map-svg" viewBox="0 0 1010 505" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
								<defs>
									<radialGradient id="earth-gradient" cx="50%" cy="50%" r="50%">
										<stop offset="85%" stop-color="rgba(10, 15, 30, 0.45)" />
										<stop offset="98%" stop-color="rgba(40, 60, 100, 0.6)" />
										<stop offset="100%" stop-color="rgba(200, 220, 255, 0.0)" />
									</radialGradient>
								</defs>
								<!-- High-fidelity country paths loaded dynamically at runtime -->
								<g id="map-paths-group"></g>
								
								<!-- Dynamic dot matrix grid container -->
								<g id="dot-grid-group"></g>
								
								<!-- Location marker - updated by JS -->
								<g id="city-marker-group" style="display: none;">
									<circle class="city-ring" id="city-ring" cx="0" cy="0" r="10"/>
									<circle class="city-marker" id="city-dot" cx="0" cy="0" r="4"/>
								</g>
							</svg>
						</div>

						<!-- Current Location Info -->
						<div class="location-footer">
							<span class="location-dot-pulse"></span>
							<span class="location-text">📍 Currently in：<strong id="current-location-display">Xi'an</strong></span>
						</div>
					</div>
				</div>

				<!-- Row 2: Status Bar / Lyric Marquee -->
				<div class="glass-card status-banner w-100">
					<div>
						<span>签名：</span>
						<span id="typing-lyric" class="lyric-text">独有南山桂花发，飞来飞去袭人裾。</span>
					</div>
					<div style="opacity: 0.7;">
						<span>🔋 系统运行稳定中</span>
					</div>
				</div>

				<!-- Row 3: Grid containing Featured Post + Right Side Widgets -->
				<div class="row-flex">
					<!-- Featured Post Card -->
					<a href={`/blog/${latestPost.id}/`} class="glass-card glass-card-hover featured-widget w-35">
						<span class="featured-tag">LATEST POST</span>
						{latestPost.data.heroImage && <Image src={latestPost.data.heroImage} alt="Cover" class="featured-img" width={400} height={200} />}
						<div>
							<h3>{latestPost.data.title}</h3>
							<p style="margin-top: 0.5rem;">{latestPost.data.description}</p>
						</div>
						<div class="featured-bottom">
							<span>阅读全文 &rarr;</span>
							<span>{formatDate(latestPost.data.pubDate)}</span>
						</div>
					</a>

					<!-- Right Columns Widget Grid -->
					<div class="w-65 right-content-grid">
						<!-- Recent Posts List -->
						<div class="glass-card recent-posts-widget">
							<h3 class="widget-title">
								<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
									<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
									<polyline points="14 2 14 8 20 8"></polyline>
									<line x1="16" y1="13" x2="8" y2="13"></line>
									<line x1="16" y1="17" x2="8" y2="17"></line>
									<polyline points="10 9 9 9 8 9"></polyline>
								</svg>
								最近发表
							</h3>
							{
								posts.map((post) => (
									<div class="post-row">
										<a href={`/blog/${post.id}/`} class="post-title-link">
											{post.data.title}
										</a>
										<span class="post-meta-tag">
											{formatDateSpaced(post.data.pubDate)}
										</span>
									</div>
								))
							}
						</div>

						<!-- Sub Row for widgets -->
						<div class="sub-row">
							<!-- Theme Display Widget -->
							<div class="glass-card theme-widget w-50">
								<div class="theme-circle">
									<!-- Light Mode Sun SVG -->
									<svg class="sun-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
										<circle cx="12" cy="12" r="5"></circle>
										<line x1="12" y1="1" x2="12" y2="3"></line>
										<line x1="12" y1="21" x2="12" y2="23"></line>
										<line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
										<line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
										<line x1="1" y1="12" x2="3" y2="12"></line>
										<line x1="21" y1="12" x2="23" y2="12"></line>
										<line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
										<line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
									</svg>
									<!-- Dark Mode Moon SVG -->
									<svg class="moon-svg" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
										<path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
									</svg>
								</div>
								<h4 id="theme-status-title">日间模式</h4>
								<p id="theme-status-desc">落樱漫舞的清晨</p>
							</div>
							
							<!-- Tech Stack Tags Widget -->
							<div class="glass-card tech-widget w-50">
								<span class="tech-badge">Astro 7.0</span>
								<span class="tech-badge">Vite 6.0</span>
								<span class="tech-badge">React 19</span>
								<span class="tech-badge">Tailwind 4</span>
								<span class="tech-badge">TypeScript</span>
								<span class="tech-badge">Glassmorphism</span>
							</div>
						</div>
					</div>
				</div>

				<!-- Row 4: Status / Footer info bar -->
				<div class="glass-card footer-bar w-100">
					<div class="footer-left">
						<div class="nixie-clock" id="nixie-clock">
							<div class="nixie-tube" id="nixie-h1"><span class="nixie-num">0</span></div>
							<div class="nixie-tube" id="nixie-h2"><span class="nixie-num">0</span></div>
							<div class="nixie-colon"><span class="nixie-dot">:</span></div>
							<div class="nixie-tube" id="nixie-m1"><span class="nixie-num">0</span></div>
							<div class="nixie-tube" id="nixie-m2"><span class="nixie-num">0</span></div>
							<div class="nixie-colon"><span class="nixie-dot">:</span></div>
							<div class="nixie-tube" id="nixie-s1"><span class="nixie-num">0</span></div>
							<div class="nixie-tube" id="nixie-s2"><span class="nixie-num">0</span></div>
						</div>
						<div class="runtime-wrapper">
							<span class="status-pulse"></span>
							<span>系统已稳定运行：<span id="runtime-counter">9天 11小时</span></span>
						</div>
					</div>
					<div class="footer-right">
						<div class="tech-badges-list">
							<span class="tech-badge-pill astro-pill">
								<span class="dot-indicator" style="background-color: #ff5e00;"></span>
								Astro 7.0
							</span>
							<span class="tech-badge-pill vite-pill">
								<span class="dot-indicator" style="background-color: #747bff;"></span>
								Vite 6.0
							</span>
							<span class="tech-badge-pill react-pill">
								<span class="dot-indicator" style="background-color: #38bdf8;"></span>
								React 19
							</span>
						</div>
						<a href="https://icp.gov.cn" target="_blank" class="icp-link">萌ICP备 20260240号</a>
					</div>
				</div>

			</div>
		</main>
		<Footer />

		<!-- Scripts for clock, status, lyrics, and theme states -->
		<script define:vars={{ CURRENT_LOCATION }}>
			// 1. Typing Lyric Effect
			const lyrics = [
				"独有南山桂花发，飞来飞去袭人裾。",
				"曾经沧海难为水，除却巫山不是云。",
				"取次花丛懒回顾，半缘修道半缘君。"
			];
			let lyricIndex = 0;
			const lyricEl = document.getElementById('typing-lyric');
			
			setInterval(() => {
				lyricIndex = (lyricIndex + 1) % lyrics.length;
				if (lyricEl) lyricEl.textContent = lyrics[lyricIndex];
			}, 6000);

			// 2. Live Nixie Clock
			const updateClock = () => {
				const now = new Date();
				const hours = String(now.getHours()).padStart(2, '0');
				const minutes = String(now.getMinutes()).padStart(2, '0');
				const seconds = String(now.getSeconds()).padStart(2, '0');
				
				const updateNixieDigit = (id, val) => {
					const el = document.getElementById(id);
					if (el) {
						const num = el.querySelector('.nixie-num');
						if (num && num.textContent !== val) {
							num.textContent = val;
						}
					}
				};

				updateNixieDigit('nixie-h1', hours[0]);
				updateNixieDigit('nixie-h2', hours[1]);
				updateNixieDigit('nixie-m1', minutes[0]);
				updateNixieDigit('nixie-m2', minutes[1]);
				updateNixieDigit('nixie-s1', seconds[0]);
				updateNixieDigit('nixie-s2', seconds[1]);
			};
			setInterval(updateClock, 1000);
			updateClock();

			// Uptime Counter
			const updateUptime = () => {
				const startDate = new Date('2026-07-05T00:00:00');
				const now = new Date();
				const diffMs = now.getTime() - startDate.getTime();
				
				const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));
				const diffHours = Math.floor((diffMs % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
				const diffMins = Math.floor((diffMs % (1000 * 60 * 60)) / (1000 * 60));
				const diffSecs = Math.floor((diffMs % (1000 * 60)) / 1000);
				
				const counterEl = document.getElementById('runtime-counter');
				if (counterEl) {
					counterEl.textContent = `${diffDays}天 ${diffHours}小时 ${diffMins}分 ${diffSecs}秒`;
				}
			};
			setInterval(updateUptime, 1000);
			updateUptime();

			// 3. Dynamic Theme Widget Status Update
			const themeTitle = document.getElementById('theme-status-title');
			const themeDesc = document.getElementById('theme-status-desc');

			const updateThemeWidget = () => {
				const isDark = document.documentElement.getAttribute('data-theme') === 'dark' ||
					(!document.documentElement.getAttribute('data-theme') && window.matchMedia('(prefers-color-scheme: dark)').matches);
				
				if (themeTitle && themeDesc) {
					if (isDark) {
						themeTitle.textContent = "夜间模式";
						themeDesc.textContent = "极光流溢的深夜";
					} else {
						themeTitle.textContent = "日间模式";
						themeDesc.textContent = "落樱漫舞的清晨";
					}
				}
			};

			// Listen for theme mutations
			const observer = new MutationObserver(updateThemeWidget);
			observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
			
			// Initial check
			updateThemeWidget();

			// 4. SVG World Map - Move city marker and dynamically render 3D dot-matrix globe
			(async () => {
				const svgMapContainer = document.getElementById('world-map-svg');
				const cityDot = document.getElementById('city-dot');
				const cityRing = document.getElementById('city-ring');
				const locationDisplay = document.getElementById('current-location-display');
				const gridGroup = document.getElementById('dot-grid-group');
				const cityMarkerGroup = document.getElementById('city-marker-group');

				const CITIES = {
					Beijing:        { coords: [116.4074, 39.9042], label: "Beijing" },
					Shanghai:       { coords: [121.4737, 31.2304], label: "Shanghai" },
					Shenzhen:       { coords: [114.0579, 22.5431], label: "Shenzhen" },
					Chengdu:        { coords: [104.0665, 30.5728], label: "Chengdu" },
					Xian:           { coords: [108.9402, 34.3416], label: "Xi'an" },
					Wuxi:           { coords: [120.3119, 31.4912], label: "Wuxi" },
					Tokyo:          { coords: [139.6917, 35.6895], label: "Tokyo" },
					Singapore:      { coords: [103.8198, 1.3521], label: "Singapore" },
					London:         { coords: [-0.1278, 51.5074], label: "London" },
					Paris:          { coords: [2.3522, 48.8566], label: "Paris" },
					"New York":     { coords: [-74.0060, 40.7128], label: "New York" },
					"San Francisco":{ coords: [-122.4194, 37.7749], label: "San Francisco" },
					Sydney:         { coords: [151.2093, -33.8688], label: "Sydney" }
				};

				const cityKey = CURRENT_LOCATION || 'Xian';
				const cityData = CITIES[cityKey] || CITIES.Xian;
				const [cityLon, cityLat] = cityData.coords;

				try {
					// Dynamically import D3.js and TopoJSON Client
					const d3 = await import('https://cdn.jsdelivr.net/npm/d3@7/+esm');
					const topojson = await import('https://cdn.jsdelivr.net/npm/topojson-client@3/+esm');
					if (!svgMapContainer || !gridGroup) return;

					// Fetch world TopoJSON (with sessionStorage caching for instant subsequent loads)
					let worldData;
					const cachedWorld = sessionStorage.getItem('worldTopoData');
					if (cachedWorld) {
						worldData = JSON.parse(cachedWorld);
					} else {
						const res = await fetch('https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json');
						worldData = await res.json();
						sessionStorage.setItem('worldTopoData', JSON.stringify(worldData));
					}
					const landFeature = topojson.feature(worldData, worldData.objects.land);

					const width = 1010;
					const height = 505;
					const globeRadius = 480; // Large radius for a massive immersive globe
					
					// "再往赤道去一点，视角再斜一点" (Tilt aggressively by 30 degrees, placing camera right at the equator)
					const tiltDegrees = 30; 
					const cameraLat = cityLat - tiltDegrees;
					
					// Shift the globe down so the city remains vertically centered on screen
					const centerYOffset = globeRadius * Math.sin(tiltDegrees * (Math.PI / 180));

					// Setup 3D Orthographic Projection with a gentle equatorial tilt
					const projection = d3.geoOrthographic()
						.scale(globeRadius)
						.translate([width / 2, height / 2 + centerYOffset])
						.rotate([-cityLon, -cameraLat, 0])
						.clipAngle(90);

					// --- ULTRA-FAST PERFORMANCE OPTIMIZATION ---
					// Render land to an offscreen canvas to avoid calling d3.geoContains 10,000+ times.
					// Canvas array lookup is O(1) and executes in microseconds vs milliseconds for Math.
					const canvas = document.createElement('canvas');
					canvas.width = 1010; // Max SVG X size
					canvas.height = 1010; // Max SVG Y size
					const ctx = canvas.getContext('2d', { willReadFrequently: true });
					const path = d3.geoPath().projection(projection).context(ctx);
					ctx.fillStyle = '#fff';
					ctx.beginPath();
					path(landFeature);
					ctx.fill();
					const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height).data;
					// -------------------------------------------

					// Draw Sphere Base (Realistic earth gradient for volumetric glow effect)
					const sphereOutline = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
					sphereOutline.setAttribute('cx', String(width / 2));
					sphereOutline.setAttribute('cy', String(height / 2 + centerYOffset));
					sphereOutline.setAttribute('r', String(globeRadius));
					sphereOutline.setAttribute('fill', 'url(#earth-gradient)'); // Natural atmospheric scattering
					sphereOutline.setAttribute('stroke', 'rgba(255, 255, 255, 0.2)'); // Crisp very faint horizon line
					sphereOutline.setAttribute('stroke-width', '0.5'); // Ultra-thin
					svgMapContainer.insertBefore(sphereOutline, gridGroup);

					// Position city marker
					const [markerX, markerY] = projection([cityLon, cityLat]);
					if (cityDot && cityRing) {
						cityDot.setAttribute('cx', String(markerX));
						cityDot.setAttribute('cy', String(markerY));
						cityRing.setAttribute('cx', String(markerX));
						cityRing.setAttribute('cy', String(markerY));
						if (cityMarkerGroup) cityMarkerGroup.style.display = 'block';
					}

					if (locationDisplay) {
						locationDisplay.textContent = cityData.label;
					}

					// Sample a 2D screen grid over the globe boundaries and back-project each point to 3D sphere
					const gridSize = 8; // Higher density for the smaller globe
					const startX = width / 2 - globeRadius;
					const endX = width / 2 + globeRadius;
					const startY = height / 2 + centerYOffset - globeRadius;
					const endY = height / 2 + centerYOffset + globeRadius;

					let dotsHTML = '';

					for (let y = startY; y <= endY; y += gridSize) {
						for (let x = startX; x <= endX; x += gridSize) {
							// Check if dot falls within the circular boundary of the globe
							const dx = x - width / 2;
							const dy = y - (height / 2 + centerYOffset);
							const distFromCenter = Math.sqrt(dx * dx + dy * dy);
							
							// Leave a 12px margin from the edge to prevent dots from entering the light atmospheric gradient
							if (distFromCenter <= globeRadius - 12) {
								// Check land status instantly via Canvas pixel lookup instead of slow d3.geoContains math
								const pixelX = Math.floor(x);
								const pixelY = Math.floor(y);
								const pixelIdx = (pixelY * canvas.width + pixelX) * 4;
								const isLand = imageData[pixelIdx + 3] > 128; // Check Alpha channel

								// Simulating depth by shrinking dots slightly near the edges
								const distToEdge = Math.sqrt(dx * dx + dy * dy) / globeRadius;
								let r = Math.max(0.8, 1.8 * (1 - distToEdge * 0.4));
								if (isLand) {
									r = r * 1.35; // Boost size of active land dots to define continents
								}
								
								const cssClass = isLand ? 'map-dot active-land' : 'map-dot';
								dotsHTML += `<circle cx="${x}" cy="${y}" r="${r}" class="${cssClass}"></circle>`;
							}
						}
					}
					
					// Ultra-fast bulk DOM insertion to prevent rendering bottlenecks
					gridGroup.innerHTML = dotsHTML;
				} catch (err) {
					console.error('Error rendering 3D dot-matrix globe:', err);
				}
			})();
		</script>
	</body>
</html>
