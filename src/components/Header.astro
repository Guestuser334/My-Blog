---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav class="glass-card">
		<h2>
			<a href="/" class="logo-link">
				<span class="logo-badge">S</span>
				<span class="logo-text">Skittles's <span class="logo-blog-span">Blog</span></span>
			</a>
		</h2>
		<div class="internal-links">
			<HeaderLink href="/">首页</HeaderLink>
			<HeaderLink href="/blog">文章</HeaderLink>
			<HeaderLink href="/about">关于</HeaderLink>
			<HeaderLink href="/links">友链</HeaderLink>
		</div>
		<div class="nav-right">
			<div class="social-links">
				<a href="https://m.webtoo.ls/@astro" target="_blank">
					<span class="sr-only">Follow Astro on Mastodon</span>
					<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
						><path
							fill="currentColor"
							d="M11.19 12.195c2.016-.24 3.77-1.475 3.99-2.603.348-1.778.32-4.339.32-4.339 0-3.47-2.286-4.488-2.286-4.488C12.062.238 10.083.017 8.027 0h-.05C5.92.017 3.942.238 2.79.765c0 0-2.285 1.017-2.285 4.488l-.002.662c-.004.64-.007 1.35.011 2.091.083 3.394.626 6.74 3.78 7.57 1.454.383 2.703.463 3.709.408 1.823-.1 2.847-.647 2.847-.647l-.06-1.317s-1.303.41-2.767.36c-1.45-.05-2.98-.156-3.215-1.928a3.614 3.614 0 0 1-.033-.496s1.424.346 3.228.428c1.103.05 2.137-.064 3.188-.189zm1.613-2.47H11.13v-4.08c0-.859-.364-1.295-1.091-1.295-.804 0-1.207.517-1.207 1.541v2.233H7.168V5.89c0-1.024-.403-1.541-1.207-1.541-.727 0-1.091.436-1.091 1.296v4.079H3.197V5.522c0-.859.22-1.541.66-2.046.456-.505 1.052-.764 1.793-.764.856 0 1.504.328 1.933.983L8 4.39l.417-.695c.429-.655 1.077-.983 1.934-.983.74 0 1.336.259 1.791.764.442.505.661 1.187.661 2.046v4.203z"
						></path></svg
					>
				</a>
				<a href="https://twitter.com/astrodotbuild" target="_blank">
					<span class="sr-only">Follow Astro on Twitter</span>
					<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
						><path
							fill="currentColor"
							d="M5.026 15c6.038 0 9.341-5.003 9.341-9.334 0-.14 0-.282-.006-.422A6.685 6.685 0 0 0 16 3.542a6.658 6.658 0 0 1-1.889.518 3.301 3.301 0 0 0 1.447-1.817 6.533 6.533 0 0 1-2.087.793A3.286 3.286 0 0 0 7.875 6.03a9.325 9.325 0 0 1-6.767-3.429 3.289 3.289 0 0 0 1.018 4.382A3.323 3.323 0 0 1 .64 6.575v.045a3.288 3.288 0 0 0 2.632 3.218 3.203 3.203 0 0 1-.865.115 3.23 3.23 0 0 1-.614-.057 3.283 3.283 0 0 0 3.067 2.277A6.588 6.588 0 0 1 .78 13.58a6.32 6.32 0 0 1-.78-.045A9.344 9.344 0 0 0 5.026 15z"
						></path></svg
					>
				</a>
				<a href="https://github.com/withastro/astro" target="_blank">
					<span class="sr-only">Go to Astro's GitHub repo</span>
					<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
						><path
							fill="currentColor"
							d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
						></path></svg
					>
				</a>
			</div>
			
			<button id="theme-toggle" class="theme-toggle" aria-label="Toggle dark mode">
				<svg class="sun" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<circle cx="12" cy="12" r="5"></circle>
					<line x1="12" y1="1" x2="12" y2="3"></line>
					<line x1="12" y1="21" x2="12" y2="23"></line>
					<line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
					<line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
					<line x1="1" y1="12" x2="3" y2="12"></line>
					<line x1="21" y1="12" x2="23" y2="12"></line>
					<line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
					<line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
				</svg>
				<svg class="moon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
				</svg>
			</button>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		width: 100%;
		background: transparent !important;
		border-bottom: none !important;
		box-shadow: none !important;
		backdrop-filter: none !important;
		-webkit-backdrop-filter: none !important;
		padding: 1.2rem 0; /* default padding */
		transition: padding 0.3s cubic-bezier(0.16, 1, 0.3, 1);
	}
	header.header-scrolled {
		padding: 0.6rem 0; /* shrink on scroll */
	}
	h2 {
		margin: 0;
		font-size: 1.15em;
	}
	.logo-link {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		text-decoration: none;
	}
	.logo-badge {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 28px;
		height: 28px;
		border-radius: 8px;
		background: linear-gradient(135deg, var(--accent), var(--accent-dark));
		color: #ffffff !important;
		font-weight: 800;
		font-size: 0.95rem;
		box-shadow: 0 4px 12px rgba(var(--accent-color), 0.35);
		text-shadow: 0 1px 2px rgba(0, 0, 0, 0.25);
		font-family: var(--font-sans);
		transition: transform 0.2s, box-shadow 0.2s;
	}
	.logo-link:hover .logo-badge {
		transform: scale(1.05) rotate(-3deg);
		box-shadow: 0 6px 16px rgba(var(--accent-color), 0.45);
	}
	.logo-text {
		font-weight: 700;
		letter-spacing: -0.02em;
		color: #ffffff !important; /* Force high contrast white logo text */
		transition: opacity 0.2s;
	}
	.logo-blog-span {
		font-weight: 800;
		color: var(--accent);
	}
	.logo-link:hover .logo-text {
		opacity: 0.85;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: 900px;
		max-width: calc(100% - 2.5rem);
		margin: 0 auto;
		box-sizing: border-box;
		padding: 0.5em 2em;
		background: rgba(16, 20, 30, 0.52) !important; /* Lighter, more transparent dark glass */
		background-clip: padding-box !important; /* Clips background to inside of the border to prevent bleed-out */
		border: 1.5px solid transparent !important; /* Transparent border allows the conic gradient to show */
		backdrop-filter: blur(20px) saturate(140%);
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25), inset 0 1px 1px rgba(255, 255, 255, 0.15) !important;
		border-radius: 20px;
		/* Completely static styling for buttery smooth scroll performance */
		transition: none;
	}
	header.header-scrolled nav {
		/* Inherit all styles statically, no color/shadow transitions on scroll */
	}
	nav a {
		padding: 0.8em 1em;
		color: rgba(255, 255, 255, 0.7) !important; /* Brighter high contrast color */
		text-decoration: none;
		font-weight: 500;
		font-size: 0.95em;
		border-radius: 10px;
		transition: color 0.2s, background-color 0.2s;
	}
	nav a:hover {
		color: #ffffff !important;
		background-color: rgba(var(--accent-color), 0.12) !important;
	}
	nav a.active {
		color: var(--accent) !important;
		background-color: rgba(var(--accent-color), 0.12) !important;
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}
	.nav-right {
		display: flex;
		align-items: center;
		gap: 1em;
	}
	.theme-toggle {
		border: none;
		background: transparent;
		cursor: pointer;
		padding: 0.5em;
		border-radius: 50%;
		color: var(--text-muted);
		display: flex;
		align-items: center;
		justify-content: center;
		transition: color 0.2s, background-color 0.2s, transform 0.2s;
	}
	.theme-toggle:hover {
		color: var(--accent);
		background-color: rgba(var(--accent-color), 0.08);
		transform: scale(1.05);
	}
	
	.sun { display: block; }
	.moon { display: none; }
	
	:root[data-theme="dark"] .sun { display: none; }
	:root[data-theme="dark"] .moon { display: block; }
	
	@media (prefers-color-scheme: dark) {
		:root:not([data-theme="light"]) .sun { display: none; }
		:root:not([data-theme="light"]) .moon { display: block; }
	}
	
	.social-links,
	.social-links a {
		display: flex;
		align-items: center;
		gap: 0.5em;
	}
	.social-links a {
		color: var(--text-muted);
		padding: 0.5em;
		border-radius: 50%;
		transition: color 0.2s, background-color 0.2s;
	}
	.social-links a:hover {
		color: var(--accent);
		background-color: rgba(var(--accent-color), 0.08);
	}
	@media (max-width: 720px) {
		header {
			width: 100%;
			margin: 0 auto;
			padding: 0.4rem 0;
			position: sticky;
			top: 0;
		}
		header.header-scrolled {
			padding: 0.3rem 0;
		}
		nav {
			width: 100%;
			max-width: calc(100% - 1.5rem);
			padding: 0.4rem 0.6rem;
			border-radius: 14px;
			gap: 0.3rem;
		}
		.logo-text {
			font-size: 0.88rem;
			white-space: nowrap;
		}
		.logo-badge {
			width: 24px;
			height: 24px;
			font-size: 0.8rem;
			border-radius: 6px;
			gap: 0;
		}
		.internal-links {
			gap: 0.1rem;
		}
		nav a {
			padding: 0.4rem 0.5rem;
			font-size: 0.82rem;
			border-radius: 8px;
		}
		.social-links {
			display: none;
		}
		.nav-right {
			gap: 0.3rem;
		}
		.theme-toggle {
			padding: 0.4rem;
		}
	}
	@media (max-width: 480px) {
		.logo-blog-span {
			display: none;
		}
		.logo-text {
			font-size: 0.85rem;
		}
		nav a {
			padding: 0.35rem 0.4rem;
			font-size: 0.78rem;
		}
	}
</style>

<script>
	const toggle = document.getElementById('theme-toggle');
	
	const getTheme = () => {
		if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
			return localStorage.getItem('theme');
		}
		return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
	};

	const setTheme = (theme) => {
		if (theme === 'dark') {
			document.documentElement.setAttribute('data-theme', 'dark');
		} else {
			document.documentElement.setAttribute('data-theme', 'light');
		}
		localStorage.setItem('theme', theme);
	};

	toggle?.addEventListener('click', () => {
		const currentTheme = getTheme();
		const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
		setTheme(newTheme);
	});

	// Dynamic scroll state to handle overlapping glassmorphism opacity & blur saturation
	const headerEl = document.querySelector('header');
	const handleScroll = () => {
		if (window.scrollY > 20) {
			headerEl?.classList.add('header-scrolled');
		} else {
			headerEl?.classList.remove('header-scrolled');
		}
	};
	window.addEventListener('scroll', handleScroll, { passive: true });
	handleScroll();
</script>
